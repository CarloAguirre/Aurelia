NODE_ENV=development
PORT=3000

DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=aurelia

CORS_ORIGINS=http://localhost:8081,http://localhost:8082,http://localhost:8083,http://localhost:8084,http://localhost:3001,http://localhost:5173
API_TOKEN_KEY=12345678901234567890123456789012
# Gestión de esquema: usar migraciones (recomendado).
