# Reference template only. Runtime reads apps/api/.env.
#
# Purpose:
# - Developer onboarding: copy to apps/api/.env and adjust local values.
# - Infrastructure onboarding: create these variables in Azure App Service / Container App / pipeline.
#
# Notes:
# - API_TOKEN_KEY is required and must have at least 32 characters.
# - AURELIA_DEMO_USER_PASSWORD is required because local seeds and smoke tests depend on it.
# - ANTHROPIC_API_KEY is optional and is used only by AI suggestion endpoints.
# - PDF translations use the self-hosted LibreTranslate service from docker-compose.yml.
# - DB_PORT=5433 matches the local docker-compose exposure in this repository.

# App runtime
NODE_ENV=development
PORT=3000

# Database connection
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=aurelia
DB_SYNCHRONIZE=false
DB_SSL=false

# CORS
CORS_ORIGINS=http://localhost:8081,http://localhost:8082,http://localhost:8083,http://localhost:8084,http://localhost:3001,http://localhost:5173

# Token and session security
API_TOKEN_KEY=changeme-local-token-key-32chars-min
API_TOKEN_TTL_SECONDS=3600
API_SESSION_TTL_SECONDS=2592000

# Rate limiting
API_RATE_LIMIT_STORE=memory
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=180

# Local auth and demo data
API_LOGIN_PASSWORD=changeme-local-login
AURELIA_DEMO_USER_PASSWORD=changeme-demo-user-password

# Optional AI suggestions provider
ANTHROPIC_API_KEY=ignorar-por-ahora

# Bilingual PDF translation (LibreTranslate)
# Use http://libretranslate:5000 when the API also runs inside docker-compose.
REPORT_TRANSLATION_URL=http://localhost:5000
REPORT_TRANSLATION_API_KEY=
REPORT_TRANSLATION_TIMEOUT_MS=30000
REPORT_TRANSLATION_REQUIRED=true

# blob storage
AZURE_STORAGE_ACCOUNT_NAME=NOMBRE_CUENTA 
AZURE_STORAGE_ACCOUNT_KEY=LLAVE_CUENTA
AZURE_STORAGE_CONTAINER_NAME=NOMBRE_CONTENEDOR

# Bus service
MOBILE_SYNC_BROKER=service-bus
AZURE_SERVICE_BUS_CONNECTION_STRING=Endpoint=sb://...
AZURE_SERVICE_BUS_TOPIC_NAME=aurelia.mobile.sync
AZURE_SERVICE_BUS_SUBSCRIPTION_INSPECTIONS=mobile-inspecciones
AZURE_SERVICE_BUS_SUBSCRIPTION_INCIDENTS=mobile-incidentes
