NODE_ENV=development
PORT=3000

DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=aurelia

# Gestión de esquema: usar migraciones (recomendado).
# Habilitar solo en desarrollo si se quiere autogenerar el esquema.
DB_SYNCHRONIZE=false

# Auth local
API_LOGIN_PASSWORD=changeme-local-login
# Debe tener al menos 32 caracteres.
API_TOKEN_KEY=changeme-local-token-key-32chars-min

# Anthropic — requerido para POST /api/ai/suggest
ANTHROPIC_API_KEY=
