{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @aurelia/contracts build && nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "migration:run:prod": "node dist/database/run-migrations.js",
    "lint": "eslint src --ext .ts",
    "test": "ts-node src/test/api-smoke.ts",
    "test:smoke": "ts-node src/test/api-smoke.ts",
    "test:scope": "ts-node src/test/api-scope-smoke.ts",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "pnpm run typeorm migration:generate ./src/database/migrations/Migration -d ./src/database/data-source.ts",
    "migration:create": "pnpm run typeorm migration:create ./src/database/migrations/Migration",
    "migration:run": "pnpm run typeorm migration:run -d ./src/database/data-source.ts",
    "migration:revert": "pnpm run typeorm migration:revert -d ./src/database/data-source.ts",
    "seed": "ts-node src/database/seeds/001-seed-phase1.ts",
    "seed:demo": "ts-node src/database/seeds/002-seed-demo-data.ts",
    "seed:finding-classifications": "ts-node src/database/seeds/003-seed-finding-classifications.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@aurelia/contracts": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.5",
    "pdfkit": "^0.17.2",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.7.0",
    "@types/pdfkit": "^0.17.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2"
  }
}