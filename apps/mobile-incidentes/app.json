{
  "expo": {
    "name": "Aurelia Incidentes",
    "slug": "aurelia-mobile-incidentes",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.aurelia.incidentes"
    },
    "plugins": ["expo-location", "expo-image-picker"]
  }
}
