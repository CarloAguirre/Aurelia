# Reference template only. Runtime reads apps/mobile-inspecciones/.env.
#
# Purpose:
# - Developer onboarding: copy to apps/mobile-inspecciones/.env.
# - Infrastructure / release onboarding: configure these values for Expo/EAS build profiles.
#
# Notes:
# - Expo only exposes variables prefixed with EXPO_PUBLIC_.
# - EXPO_PUBLIC_API_URL must point to the reachable API base URL including /api.
# - When testing on a physical device, localhost usually does not work; use the host machine LAN IP.

# Public API base URL consumed by the mobile client
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# Allowed parent origin for the desktop-launch bridge when mobile runs on web
EXPO_PUBLIC_WEB_PARENT_ORIGIN=http://localhost:5173
