{
  "expo": {
    "name": "Aurelia Inspecciones",
    "slug": "aurelia-mobile-inspecciones",
    "scheme": "aurelia-inspecciones",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.aurelia.inspecciones"
    },
    "plugins": [
      "expo-location",
      "expo-image-picker",
      "expo-router"
    ]
  }
}
