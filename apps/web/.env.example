# Reference template only. Runtime reads apps/web/.env.
#
# Purpose:
# - Developer onboarding: copy to apps/web/.env.
# - Infrastructure onboarding: configure these variables in the web hosting environment.
#
# Notes:
# - Vite only exposes variables prefixed with VITE_.
# - VITE_API_URL must point to the public API base URL including /api.

# Public API base URL consumed by the web client
VITE_API_URL=http://localhost:3000/api
