# ──────────────────────────────────────────────
# Locations
# ──────────────────────────────────────────────

### List locations
GET {{baseUrl}}/api/organization/locations

### Create location
POST {{baseUrl}}/api/organization/locations
Content-Type: application/json

{
  "name": "Bodega Principal",
  "code": "LOC-001",
  "latitude": -33.4569,
  "longitude": -70.6483,
  "altitudeM": 520.0,
  "macrozone": "Zona Centro"
}

# ──────────────────────────────────────────────
# Users
# ──────────────────────────────────────────────

### List users
GET {{baseUrl}}/api/users

### Create user
# @name createUser
POST {{baseUrl}}/api/users
Content-Type: application/json

{
  "email": "juan.perez@aurelia.local",
  "firstName": "Juan",
  "lastName": "Pérez",
  "position": "Inspector de campo",
  "phone": "+56912345678"
}

### Create user — duplicate email (expect 409)
POST {{baseUrl}}/api/users
Content-Type: application/json

{
  "email": "juan.perez@aurelia.local",
  "firstName": "Juan",
  "lastName": "Duplicado"
}

### Get user by id
# Replace with a real UUID from the createUser response
GET {{baseUrl}}/api/users/00000000-0000-0000-0000-000000000000

# ──────────────────────────────────────────────
# User assignments (replace UUIDs as needed)
# ──────────────────────────────────────────────

@userId = 00000000-0000-0000-0000-000000000000
@roleId = 00000000-0000-0000-0000-000000000001
@companyId = 00000000-0000-0000-0000-000000000002
@areaId = 00000000-0000-0000-0000-000000000003

### Assign role to user
POST {{baseUrl}}/api/users/{{userId}}/roles
Content-Type: application/json

{
  "roleId": "{{roleId}}"
}

### Assign company to user
POST {{baseUrl}}/api/users/{{userId}}/companies
Content-Type: application/json

{
  "companyId": "{{companyId}}"
}

### Assign area to user
POST {{baseUrl}}/api/users/{{userId}}/areas
Content-Type: application/json

{
  "areaId": "{{areaId}}"
}

# ──────────────────────────────────────────────
# Roles
# ──────────────────────────────────────────────

### List roles
GET {{baseUrl}}/api/roles

### Create role
POST {{baseUrl}}/api/roles
Content-Type: application/json

{
  "code": "OPERATOR",
  "name": "Operador",
  "description": "Rol de operador de planta"
}

# ──────────────────────────────────────────────
# Permissions
# ──────────────────────────────────────────────

# ──────────────────────────────────────────────
# Permissions
# ──────────────────────────────────────────────

### List permissions
GET {{baseUrl}}/api/permissions

### Create permission
POST {{baseUrl}}/api/permissions
Content-Type: application/json

{
  "code": "inspections:read",
  "name": "Ver inspecciones",
  "module": "inspections",
  "action": "read"
}

### Assign permission to role
@permissionRoleId = 00000000-0000-0000-0000-000000000004
@permissionId = 00000000-0000-0000-0000-000000000005

POST {{baseUrl}}/api/roles/{{permissionRoleId}}/permissions
Content-Type: application/json

{
  "permissionId": "{{permissionId}}"
}
