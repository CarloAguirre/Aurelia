### Aurelia API — Phase 1 collection (VS Code REST Client)
### https://marketplace.visualstudio.com/items?itemName=humao.rest-client

@baseUrl = http://localhost:3000

# ──────────────────────────────────────────────
# Health
# ──────────────────────────────────────────────

### Health check
GET {{baseUrl}}/api/health

# ──────────────────────────────────────────────
# Me (placeholder — no auth in Phase 1)
# ──────────────────────────────────────────────

### Get current user (placeholder)
GET {{baseUrl}}/api/me

# ──────────────────────────────────────────────
# Companies
# ──────────────────────────────────────────────

### List companies
GET {{baseUrl}}/api/organization/companies

### Create company
# @name createCompany
POST {{baseUrl}}/api/organization/companies
Content-Type: application/json

{
  "name": "Contratista Ejemplo",
  "code": "CTR-001",
  "taxId": "76543210-9",
  "companyType": "contractor",
  "isContractor": true
}

### Create company — duplicate (expect 409)
POST {{baseUrl}}/api/organization/companies
Content-Type: application/json

{
  "name": "Contratista Ejemplo",
  "code": "CTR-001",
  "isContractor": true
}

# ──────────────────────────────────────────────
# Business Units
# ──────────────────────────────────────────────

### List business units
GET {{baseUrl}}/api/organization/business-units

### Create business unit
# @name createBU
POST {{baseUrl}}/api/organization/business-units
Content-Type: application/json

{
  "code": "BU-002",
  "name": "Unidad Norte",
  "description": "Operaciones zona norte"
}

### Create business unit — duplicate code (expect 409)
POST {{baseUrl}}/api/organization/business-units
Content-Type: application/json

{
  "code": "BU-002",
  "name": "Duplicada"
}

